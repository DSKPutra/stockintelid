# =============================================================================
# IDX App — contoh environment. Salin ke .env dan isi nilai nyata.
# JANGAN commit .env yang berisi kredensial. Semua sumber data dikonfigurasi
# lewat env agar tidak ada yang ter-hardcode (lihat data ingestion layer).
# =============================================================================

# ---- API server ----
API_PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# ---- Auth (skeleton M1) ----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ---- Data provider selection (provider/adapter pattern) ----
# Urutan prioritas/fallback dipisah koma. M1 hanya "mock".
# Contoh nanti: MARKET_DATA_PROVIDERS=vendorA,vendorB,mock
MARKET_DATA_PROVIDERS=mock

# ---- Vendor data pasar pihak ketiga (DIISI saat ada lisensi) ----
# LEGAL: hormati Terms of Service tiap vendor sebelum mengaktifkan.
MARKET_VENDOR_BASE_URL=
MARKET_VENDOR_API_KEY=

# ---- LLM provider untuk chatbot (M4) ----
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-opus-4-8

# ---- Database (dipakai mulai M2; lihat docker-compose.yml) ----
DATABASE_URL=postgresql://idx:idx@localhost:5432/idx
REDIS_URL=redis://localhost:6379

# ---- Frontend ----
# Base URL API yang dipakai aplikasi Expo (web & device).
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
