{
  "name": "idx-app",
  "version": "0.1.0",
  "private": true,
  "description": "Aplikasi analisa saham IDX (web + mobile + backend) dari satu codebase. Alat informasi/edukasi, bukan rekomendasi investasi.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace @idx/shared",
    "dev:api": "npm run start:dev --workspace @idx/api",
    "dev:web": "npm run web --workspace @idx/mobile",
    "dev": "npm run build:shared && concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
